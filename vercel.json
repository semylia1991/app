{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/gemini.mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/gemini",
      "destination": "/api/gemini"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
